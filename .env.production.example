KIWIGUARD_IMAGE=ghcr.io/howmuchsec/kiwiguard:dev

# Public TLS host for the OpenAI-compatible gateway.
KIWIGUARD_PUBLIC_GATEWAY_HOST=gateway.example.com

# Optional. Prefer keeping the control plane private through VPN, SSH tunnel, or localhost binding.
KIWIGUARD_PUBLIC_CONTROL_HOST=localhost

KIWIGUARD_CONTROL_AUTH_TOKEN=replace-with-long-random-token

KIWIGUARD_POSTGRES_PASSWORD=replace-with-long-random-password
KIWIGUARD_CLICKHOUSE_PASSWORD=replace-with-long-random-password

# Optional beta upstream credential sources. Use credential_ref values such as
# env:KIWIGUARD_BETA_OPENAI_API_KEY or secret/openai.
KIWIGUARD_BETA_OPENAI_API_KEY=
KIWIGUARD_CREDENTIAL_SECRET_OPENAI=

KIWIGUARD_LOG_LEVEL=info
KIWIGUARD_MAX_BODY_BYTES=1048576
KIWIGUARD_EVENT_QUEUE_CAPACITY=1024
KIWIGUARD_EVENT_BATCH_SIZE=100
KIWIGUARD_EVENT_SPOOL_MAX_BYTES=1073741824
KIWIGUARD_EVENT_SPOOL_MAX_AGE=24h
KIWIGUARD_EVENT_SPOOL_REPLAY_INTERVAL=5s
KIWIGUARD_EVENT_SPOOL_BATCH_SIZE=100

KIWIGUARD_UPSTREAM_TIMEOUT=30s
KIWIGUARD_VERDICT_TIMEOUT=5s
KIWIGUARD_SERVER_READ_HEADER_TIMEOUT=5s
KIWIGUARD_SERVER_READ_TIMEOUT=15s
KIWIGUARD_SERVER_WRITE_TIMEOUT=60s
KIWIGUARD_SERVER_IDLE_TIMEOUT=120s
KIWIGUARD_SHUTDOWN_TIMEOUT=10s
